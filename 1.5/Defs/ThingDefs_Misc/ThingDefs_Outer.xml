<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<ThingDef ParentName="GW_HOI_OuterBase">
        <defName>GW_HOI_DM_KriegCommissarOuter</defName>
        <label>Krieg Commissar Coat</label>
        <description>A flowing commissar's jacket which has been modified to withstand the harsh conditions of trench warfare. Such displays of ostentation rarely last within the trenches, as bright colors and gold filigree make for excellent targets. </description>
        <recipeMaker>
            <researchPrerequisite>GW_AM_OfficersOfAM</researchPrerequisite>
        </recipeMaker>
        <graphicData>
            <texPath>Apparel/Commissar/DKoK_CommissarOuter</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <costStuffCount>90</costStuffCount>
        <stuffCategories>
            <li>Fabric</li>
            <li>Leathery</li>
        </stuffCategories>
        <thingCategories>
            <li>ApparelMisc</li>
        </thingCategories>
        <statBases>
            <MaxHitPoints>190</MaxHitPoints>
            <WorkToMake>14000</WorkToMake>
            <Mass>2.2</Mass>
            <StuffEffectMultiplierArmor>0.3</StuffEffectMultiplierArmor>
            <StuffEffectMultiplierInsulation_Cold>0.8</StuffEffectMultiplierInsulation_Cold>
            <StuffEffectMultiplierInsulation_Heat>0.1</StuffEffectMultiplierInsulation_Heat>
            <EquipDelay>2</EquipDelay>
            <MarketValue>250</MarketValue>
        </statBases>
        <equippedStatOffsets>
            <SocialImpact>0.05</SocialImpact>
            <SlaveSuppressionOffset MayRequire="Ludeon.Rimworld.Ideology">0.05</SlaveSuppressionOffset>
            <MentalBreakThreshold>0.05</MentalBreakThreshold>
        </equippedStatOffsets>
        <apparel>
            <wornGraphicPath>Apparel/Commissar/Outer/DKoK_CommissarOuter</wornGraphicPath>
            <tags>
                <li>40kCommissar</li>
                <li>40kCommissarOuter</li>
            </tags>
        </apparel>
        <tradeTags>
            <li>HPOuter</li>
        </tradeTags>
    </ThingDef>   

    <ThingDef ParentName="GW_HOI_OuterBase">
        <defName>GW_HOI_DM_KriegOfficerOuter</defName>
        <label>Krieg officer jacket</label>
        <description>A simple leather overcoat worn over-the-shoulder in the style of a Death Korps officer. These jackets are usually stiched with simple insignia to denote rank, bearing little else in the way of decoration. </description>
        <recipeMaker>
            <researchPrerequisite>GW_AM_OfficersOfAM</researchPrerequisite>
        </recipeMaker>
        <graphicData>
            <texPath>Apparel/Officer/DKoK_OfficerOuter</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <costStuffCount>95</costStuffCount>
        <stuffCategories>
            <li>Fabric</li>
            <li>Leathery</li>
        </stuffCategories>
        <thingCategories>
            <li>ApparelMisc</li>
        </thingCategories>
        <statBases>
            <MaxHitPoints>200</MaxHitPoints>
            <WorkToMake>15000</WorkToMake>
            <Mass>2.5</Mass>
            <StuffEffectMultiplierArmor>0.3</StuffEffectMultiplierArmor>
            <StuffEffectMultiplierInsulation_Cold>0.8</StuffEffectMultiplierInsulation_Cold>
            <StuffEffectMultiplierInsulation_Heat>0.1</StuffEffectMultiplierInsulation_Heat>
            <EquipDelay>2</EquipDelay>
            <MarketValue>300</MarketValue>
        </statBases>
        <equippedStatOffsets>
            <SocialImpact>0.10</SocialImpact>
            <SlaveSuppressionOffset MayRequire="Ludeon.Rimworld.Ideology">0.15</SlaveSuppressionOffset>
            <MentalBreakThreshold>0.025</MentalBreakThreshold>
        </equippedStatOffsets>
        <apparel>
            <wornGraphicPath>Apparel/Officer/Outer/DKoK_OfficerOuter</wornGraphicPath>
            <tags>
                <li>40kGuardOfficerUniform</li>
                <li>40kKriegOfficerUniform</li>
            </tags>
        </apparel>
        <tradeTags>
            <li>HPOuter</li>
        </tradeTags>
    </ThingDef>  
</Defs>
